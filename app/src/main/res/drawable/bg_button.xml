<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape><solid android:color="@color/accent_light"/><corners android:radius="14dp"/></shape>
    </item>
    <item android:state_enabled="false">
        <shape><solid android:color="@color/divider"/><corners android:radius="14dp"/></shape>
    </item>
    <item>
        <shape><solid android:color="@color/accent"/><corners android:radius="14dp"/></shape>
    </item>
</selector>
