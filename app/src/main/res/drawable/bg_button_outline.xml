<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape><solid android:color="@color/accent_dim"/><corners android:radius="12dp"/><stroke android:width="1dp" android:color="@color/accent"/></shape>
    </item>
    <item>
        <shape><solid android:color="@android:color/transparent"/><corners android:radius="12dp"/><stroke android:width="1dp" android:color="@color/accent"/></shape>
    </item>
</selector>
